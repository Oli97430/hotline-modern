    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.372.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tauri-apps/api": "^1.5.6",
